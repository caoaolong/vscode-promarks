{
    "name": "vscode-promarks",
    "displayName": "vscode-promarks",
    "publisher": "codingsoul",
    "icon": "logo.png",
    "description": "项目收藏夹插件，用于收藏和管理常用项目。在未打开工作区时提供简洁的启动页面，集中展示已收藏的项目，支持一键快速打开，让开发者更高效地进入常用工程。 🚀",
    "version": "0.0.3",
    "engines": {
        "vscode": "^1.105.1"
    },
    "categories": [
        "Other"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/caoaolong/vscode-promarks.git"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "vscode-promarks.showWelcomePage",
                "title": "Show Project Manager"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.105.1",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.2",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0",
        "webpack": "^5.104.1",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@vscode/codicons": "^0.0.44"
    }
}
